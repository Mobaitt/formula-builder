{
  "name": "formula-builder",
  "private": false,
  "version": "1.0.3",
  "type": "module",
  "description": "A low-code formula editor for Vue 3 — token-based, drag & drop, extensible.",
  "keywords": [
    "vue3",
    "formula",
    "editor",
    "low-code",
    "token",
    "element-plus"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mobaitt/formula-builder.git"
  },
  "main": "dist/formula-builder.umd.cjs",
  "module": "dist/formula-builder.js",
  "types": "dist/entry/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/formula-builder.js",
      "require": "./dist/formula-builder.umd.cjs",
      "types": "./dist/entry/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "element-plus": "^2.14.2",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vite-plugin-css-injected-by-js": "^5.0.1",
    "vue-tsc": "^3.3.5"
  },
  "peerDependencies": {
    "element-plus": "^2.x",
    "vue": "^3.x"
  }
}
